# ════════════════════════════════════════════════════════
#  RentBuddy — Environment Variables
#  Copy this file to .env.local and fill in the values
#  cp .env.example .env.local
# ════════════════════════════════════════════════════════

# ── REQUIRED (app won't start without these) ─────────────

# MongoDB Atlas connection string
# Get free M0 cluster at cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/rentbuddy
MONGODB_URI=

# NextAuth secret — any random string (min 32 chars)
# Generate one: openssl rand -base64 32
NEXTAUTH_SECRET=rentbuddy-dev-secret-change-this-in-production

# Your app URL (use localhost for local dev)
NEXTAUTH_URL=http://localhost:3000


# ── OPTIONAL — add as you need each feature ──────────────

# Google OAuth (sign in with Google)
# Get from console.cloud.google.com → Credentials → OAuth 2.0
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Magic link email (sign in via email link)
# Use Resend (resend.com) for easy setup
# EMAIL_SERVER=smtp://username:password@smtp.resend.com:465
# EMAIL_FROM=RentBuddy <noreply@rentbuddy.app>

# Meta Llama 3 AI (roommate matching + lease scanner)
# Free credits at api.together.xyz
# TOGETHER_API_KEY=
# TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# Twilio SMS (rent payment reminders)
# Get from console.twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Coinbase Commerce (crypto rent payments)
# Get from commerce.coinbase.com
# COINBASE_COMMERCE_API_KEY=
# COINBASE_COMMERCE_WEBHOOK_SECRET=

# Mapbox (interactive housing map)
# Free token at mapbox.com
# NEXT_PUBLIC_MAPBOX_TOKEN=

# RentIts API (+40 bonus points per signup)
# Contact the RentIts team at rentits.in
# RENTITS_API_KEY=
# RENTITS_API_URL=https://api.rentits.in/v1
